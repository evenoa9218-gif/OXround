<!DOCTYPE html>

<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>유니온 MGI Point OX 퀴즈 허브</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;500;600;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Noto Serif KR',serif;background:#f5f4f0;color:#1a1a18;min-height:100vh}
.app{max-width:800px;margin:0 auto;padding:16px 14px 60px}
.hdr{text-align:center;padding:24px 0 18px;border-bottom:1px solid #ddd;margin-bottom:20px}
.hdr-sub{font-size:11px;color:#888;letter-spacing:2.5px;margin-bottom:8px}
.hdr-title{font-size:24px;font-weight:700;color:#1a1a18}
.hdr-sub2{font-size:12px;color:#aaa;margin-top:6px}
.btn{font-family:'Noto Serif KR',serif;cursor:pointer;border-radius:10px;font-size:13px;padding:10px 14px;transition:all .15s;border:1px solid #ccc;background:#fff;color:#1a1a18}
.btn:hover{background:#f0ede8}.btn:active{transform:scale(.98)}
.btn-p{background:#1a1a18;color:#fff;border:none;font-weight:600}.btn-p:hover{background:#333}
.rst{font-family:'Noto Serif KR',serif;font-size:11px;color:#aaa;background:none;border:1px solid #ddd;border-radius:8px;padding:6px 12px;cursor:pointer}
.rst:hover{color:#c62828;border-color:#e57373}
.sec{font-size:11px;color:#888;letter-spacing:1px;margin-bottom:10px;padding-left:2px}
/* 로그인 */
.login-wrap{min-height:75vh;display:flex;align-items:center;justify-content:center;padding:20px}
.login-box{width:100%;max-width:360px}
.login-card{background:#fff;border:1px solid #e0ddd6;border-radius:14px;padding:26px}
.input-field{width:100%;font-family:'Noto Serif KR',serif;font-size:14px;padding:11px 14px;border:1px solid #ddd;border-radius:10px;outline:none;background:#fafaf8;color:#1a1a18;margin-bottom:10px;transition:border .15s}
.input-field:focus{border-color:#1a1a18}
/* 퀴즈 카드 */
.quiz-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-bottom:20px}
.quiz-card{background:#fff;border:1px solid #e0ddd6;border-radius:14px;padding:16px 18px;cursor:pointer;transition:all .15s;text-align:left;position:relative;overflow:hidden}
.quiz-card:hover{border-color:#1a1a18;transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.08)}
.quiz-card:active{transform:scale(.99)}
.quiz-card-label{font-size:10px;color:#aaa;letter-spacing:1px;margin-bottom:5px}
.quiz-card-title{font-size:14px;font-weight:700;color:#1a1a18;margin-bottom:10px;line-height:1.4}
.quiz-card-meta{font-size:11px;color:#888;display:flex;gap:10px;flex-wrap:wrap}
.quiz-card-bar{height:3px;background:#e0ddd6;border-radius:2px;margin-top:12px;overflow:hidden}
.quiz-card-bar-fill{height:100%;background:#1a1a18;border-radius:2px;transition:width .4s}
.badge{display:inline-block;font-size:10px;padding:2px 7px;border-radius:20px;background:#f0ede8;color:#888;margin-bottom:8px}
/* 관리자 */
.user-row{background:#fff;border:1px solid #e0ddd6;border-radius:12px;padding:14px 16px;margin-bottom:8px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.stat-chip{font-size:12px;color:#888}
</style>
</head>
<body>
<div class="app" id="root"><div style="text-align:center;padding:60px;color:#888">불러오는 중...</div></div>

<script type="module">
// ── Firebase 설정
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getDatabase, ref, get, set, update, child } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

const firebaseConfig = {
  apiKey: "AIzaSyCrVPnha-pqrAyTYMdSvYP036HsJGJEMxw",
  authDomain: "union-mgipoint-ox-quiz.firebaseapp.com",
  databaseURL: "https://union-mgipoint-ox-quiz-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "union-mgipoint-ox-quiz",
  storageBucket: "union-mgipoint-ox-quiz.firebasestorage.app",
  messagingSenderId: "1187923060",
  appId: "1:1187923060:web:2cebb02a328f8d3c3c3d21"
};

const app = initializeApp(firebaseConfig);
const db  = getDatabase(app);

// ── 관리자 설정
const ADMIN_ID = 'admin';
const ADMIN_PW = 'mgi2025!'; // ← 여기서 비밀번호 변경

// ── 상태
let currentUser = null;

// ── 유틸
const root = () => document.getElementById('root');
const $ = id => document.getElementById(id);

// ── Firebase 헬퍼
async function fbGet(path){ const snap = await get(ref(db, path)); return snap.exists() ? snap.val() : null; }
async function fbSet(path, val){ await set(ref(db, path), val); }
async function fbUpdate(path, val){ await update(ref(db, path), val); }

// ── 사용자 기록 로드
async function loadUserRecord(uid, quizId){
  return await fbGet(`users/${uid}/${quizId}`) || {qS:{},tS:{},ov:{c:0,w:0,n:0},banks:{0:[],1:[],2:[],3:[],4:[]}};
}

// ── 퀴즈 목록 로드
async function loadQuizList(){
  return await fbGet('quizzes') || {};
}

// ──────────────────────────────────────────
// 초기화
// ──────────────────────────────────────────
async function init(){
  const last = localStorage.getItem('mgi_hub_user') || '';
  renderLogin(last);
}

// ──────────────────────────────────────────
// 로그인 화면
// ──────────────────────────────────────────
function renderLogin(prefill=''){
  root().innerHTML = `
  <div class="login-wrap">
  <div class="login-box">
    <div style="text-align:center;margin-bottom:28px">
      <div style="font-size:11px;color:#888;letter-spacing:2.5px;margin-bottom:8px">UNION LAW · MGI POINT</div>
      <div style="font-size:24px;font-weight:700;color:#1a1a18">OX 퀴즈 허브</div>
      <div style="font-size:12px;color:#aaa;margin-top:6px">아이디로 로그인하면 어느 기기에서든<br>내 학습 기록이 이어집니다</div>
    </div>
    <div class="login-card">
      <div style="font-size:12px;color:#888;margin-bottom:8px">아이디</div>
      <input id="uid-input" class="input-field" type="text" placeholder="영문·숫자·한글 20자 이내" value="${prefill}"
        oninput="window._togglePw()" onkeydown="if(event.key==='Enter')window._doLogin()">
      <div id="pw-wrap" style="display:none">
        <div style="font-size:12px;color:#888;margin-bottom:8px">관리자 비밀번호</div>
        <input id="pw-input" class="input-field" type="password" placeholder="비밀번호 입력"
          onkeydown="if(event.key==='Enter')window._doLogin()">
      </div>
      <button class="btn btn-p" style="width:100%;padding:13px;font-size:14px" onclick="window._doLogin()">시작하기</button>
      <div style="font-size:11px;color:#bbb;text-align:center;margin-top:12px">같은 아이디로 어디서든 이어서 풀 수 있습니다</div>
    </div>
  </div>
  </div>`;
  setTimeout(()=>{ const el=$('uid-input'); if(el) el.focus(); }, 100);
}

window._togglePw = () => {
  const uid = ($('uid-input')||{}).value||'';
  const wrap = $('pw-wrap');
  if(wrap) wrap.style.display = uid.trim()===ADMIN_ID ? 'block' : 'none';
};

window._doLogin = async () => {
  const uid = ($('uid-input')||{}).value.trim();
  if(!uid){ if($('uid-input')) $('uid-input').style.borderColor='#e57373'; return; }
  if(!/^[a-zA-Z0-9가-힣_-]{1,20}$/.test(uid)){ alert('아이디는 20자 이내 영문/숫자/한글만 가능합니다.'); return; }

  if(uid === ADMIN_ID){
    const pw = ($('pw-input')||{}).value||'';
    if(pw !== ADMIN_PW){ alert('관리자 비밀번호가 틀렸습니다.'); return; }
    currentUser = ADMIN_ID;
    localStorage.setItem('mgi_hub_user', ADMIN_ID);
    root().innerHTML = '<div style="text-align:center;padding:60px;color:#888">데이터 불러오는 중...</div>';
    await renderAdmin();
    return;
  }

  currentUser = uid;
  localStorage.setItem('mgi_hub_user', uid);
  root().innerHTML = '<div style="text-align:center;padding:60px;color:#888">기록 불러오는 중...</div>';
  await renderHub();
};

// ──────────────────────────────────────────
// 허브 (일반 사용자)
// ──────────────────────────────────────────
async function renderHub(){
  const quizzes = await loadQuizList();
  const ids = Object.keys(quizzes);

  // 각 퀴즈별 사용자 기록 병렬 로드
  const records = {};
  await Promise.all(ids.map(async id => {
    records[id] = await loadUserRecord(currentUser, id);
  }));

  let cards = '';
  if(ids.length === 0){
    cards = '<div style="text-align:center;padding:40px;color:#aaa">아직 등록된 퀴즈가 없습니다</div>';
  } else {
    cards = ids.map(id => {
      const q = quizzes[id];
      const rec = records[id];
      const ov = rec.ov || {c:0,w:0,n:0};
      const pct = ov.n ? Math.round(ov.c/ov.n*100) : null;
      const b0 = (rec.banks&&rec.banks[0]||[]).length;
      const barW = pct !== null ? pct : 0;
      return `
      <button class="quiz-card" onclick="window._openQuiz('${id}')">
        <div class="badge">${q.subject||'민법'}</div>
        <div class="quiz-card-title">${q.title}</div>
        <div class="quiz-card-meta">
          <span>📝 ${q.qCount}문제</span>
          <span>📚 ${q.topicCount}주제</span>
          ${ov.n ? `<span class="ok">✓${ov.c}</span><span class="er">✗${ov.w}</span>` : '<span style="color:#ccc">미풀이</span>'}
          ${b0>0?`<span style="color:#c62828">오답 ${b0}</span>`:''}
        </div>
        ${ov.n?`<div class="quiz-card-bar"><div class="quiz-card-bar-fill" style="width:${barW}%"></div></div>`:''}
      </button>`;
    }).join('');
  }

  root().innerHTML = `
  <div class="hdr">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
      <div style="font-size:11px;color:#888;letter-spacing:2px">UNION LAW · MGI POINT</div>
      <button class="rst" onclick="window._logout()">👤 ${currentUser} · 로그아웃</button>
    </div>
    <div class="hdr-title">OX 퀴즈 허브</div>
    <div class="hdr-sub2">과목을 선택하세요</div>
  </div>
  <div class="sec">전체 과목 (${ids.length})</div>
  <div class="quiz-grid">${cards}</div>`;
}

window._openQuiz = (quizId) => {
  // 퀴즈 페이지로 파라미터 전달
  const url = `quiz.html?id=${quizId}&user=${encodeURIComponent(currentUser)}`;
  window.location.href = url;
};

window._logout = () => {
  currentUser = null;
  localStorage.removeItem('mgi_hub_user');
  renderLogin();
};

// ──────────────────────────────────────────
// 관리자 화면
// ──────────────────────────────────────────
async function renderAdmin(){
  const [quizzes, usersData] = await Promise.all([
    fbGet('quizzes'),
    fbGet('users')
  ]);

  const qList = quizzes || {};
  const uData = usersData || {};
  const uIds = Object.keys(uData).filter(u => u !== ADMIN_ID);

  // 사용자별 요약
  const userRows = uIds.length === 0
    ? '<div style="text-align:center;padding:24px;color:#aaa">아직 학습 기록이 없습니다</div>'
    : uIds.map(uid => {
        // 전체 과목 합산
        let totalN=0, totalC=0, totalW=0;
        Object.values(uData[uid]||{}).forEach(rec => {
          const ov = rec.ov||{c:0,w:0,n:0};
          totalN+=ov.n; totalC+=ov.c; totalW+=ov.w;
        });
        const pct = totalN ? Math.round(totalC/totalN*100) : null;
        return `
        <div class="user-row">
          <div style="font-size:14px;font-weight:600;min-width:90px">👤 ${uid}</div>
          <div style="flex:1;display:flex;gap:10px;flex-wrap:wrap">
            <span class="stat-chip">시도 <b>${totalN}</b></span>
            <span class="stat-chip ok">정답 <b>${totalC}</b></span>
            <span class="stat-chip er">오답 <b>${totalW}</b></span>
            ${pct!==null?`<span class="stat-chip wa">정답률 <b>${pct}%</b></span>`:''}
          </div>
          <button class="rst" style="margin-top:0" onclick="window._adminViewUser('${uid}')">상세보기</button>
        </div>`;
      }).join('');

  const quizRows = Object.keys(qList).length === 0
    ? '<div style="text-align:center;padding:24px;color:#aaa">등록된 퀴즈 없음</div>'
    : Object.entries(qList).map(([id,q])=>`
        <div class="user-row">
          <div style="flex:1"><div style="font-weight:600">${q.title}</div>
          <div style="font-size:11px;color:#888;margin-top:3px">${q.qCount}문제 · ${q.topicCount}주제 · ID: ${id}</div></div>
        </div>`).join('');

  root().innerHTML = `
  <div class="hdr">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
      <div style="font-size:11px;color:#888;letter-spacing:2px">UNION LAW · 관리자</div>
      <button class="rst" onclick="window._logout()">로그아웃</button>
    </div>
    <div class="hdr-title">📋 관리자 대시보드</div>
  </div>

  <div class="sec">등록된 퀴즈 (${Object.keys(qList).length})</div>
  ${quizRows}

  <div class="sec" style="margin-top:20px">전체 사용자 (${uIds.length}명)</div>
  <div style="margin-bottom:10px">
    <button class="btn btn-p" style="font-size:12px;padding:8px 14px" onclick="renderAdmin()">🔄 새로고침</button>
  </div>
  ${userRows}`;
}

window._adminViewUser = async (uid) => {
  const [quizzes, userRecs] = await Promise.all([
    fbGet('quizzes'),
    fbGet(`users/${uid}`)
  ]);
  const qList = quizzes||{};
  const recs = userRecs||{};

  const sections = Object.entries(qList).map(([qid, q])=>{
    const rec = recs[qid]||{ov:{c:0,w:0,n:0}};
    const ov = rec.ov||{c:0,w:0,n:0};
    const pct = ov.n ? Math.round(ov.c/ov.n*100) : null;
    return `
    <div style="background:#fff;border:1px solid #e0ddd6;border-radius:12px;padding:14px 16px;margin-bottom:8px">
      <div style="font-weight:600;margin-bottom:8px">${q.title}</div>
      <div style="display:flex;gap:12px;font-size:12px;flex-wrap:wrap">
        <span class="stat-chip">시도 <b>${ov.n}</b></span>
        <span class="stat-chip ok">정답 <b>${ov.c}</b></span>
        <span class="stat-chip er">오답 <b>${ov.w}</b></span>
        ${pct!==null?`<span class="stat-chip wa">정답률 <b>${pct}%</b></span>`:'<span style="color:#ccc;font-size:12px">미풀이</span>'}
      </div>
    </div>`;
  }).join('');

  root().innerHTML = `
  <div style="padding-top:10px">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
      <button class="btn" style="padding:8px 12px;font-size:12px" onclick="renderAdmin()">← 목록으로</button>
      <div style="font-size:16px;font-weight:700">👤 ${uid}</div>
    </div>
    <div class="sec">과목별 학습 현황</div>
    ${sections||'<div style="color:#aaa;font-size:13px">기록 없음</div>'}
  </div>`;
};

window._logout = () => {
  currentUser = null;
  localStorage.removeItem('mgi_hub_user');
  renderLogin();
};

// ── 시작
init();
</script>

</body>
</html>